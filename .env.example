# Copy this file to `.env` for Docker Compose live-mode connector wiring.
# Values are command strings, not API keys. Keep credentials in connector auth stores.

# Required for live Jira polling. This scopes autonomous work to one Jira project.
JIRA_PROJECT_KEY=

# Optional. Leave blank to let the runner discover the first accessible Atlassian cloud.
JIRA_CLOUD_ID=

# Remote OAuth MCP bridge example for Atlassian Jira.
MCP_JIRA_COMMAND=npx -y mcp-remote https://mcp.atlassian.com/v1/sse 3334 --host 0.0.0.0 --auth-timeout 120 --transport sse-only

# GitHub should use an SSO-backed enterprise MCP connector command when available.
MCP_GITHUB_COMMAND=

# Configure these with your enterprise MCP connector commands when available.
MCP_NOTION_COMMAND=
MCP_MIRO_COMMAND=
MCP_FIGMA_COMMAND=
MCP_LOVABLE_COMMAND=

# Local service examples for the Docker Compose network.
MCP_POSTGRES_COMMAND=npx -y @modelcontextprotocol/server-postgres postgresql://symphony@postgres:5432/symphony
MCP_CHROMA_COMMAND=
